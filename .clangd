CompileFlags:
  Add:
    # ANTLR4 runtime headers
    - -I/usr/local/include/antlr4-runtime
    - -I/usr/include/antlr4-runtime
    - -I/antlr4-runtime

    # LLVM/MLIR headers
    - -I/usr/lib/llvm-20/include
    - -I/usr/include/llvm-20

    # Project headers
    - -Iinclude
    - -Iinclude/zenith
    - -Icmake-build-debug/include

    # Generated headers
    - -Icmake-build-debug/antlr4gen

    # System includes
    - -I/usr/include/c++/14
    - -I/usr/include/x86_64-linux-gnu/c++/14
    - -I/usr/include/c++/14/backward
    - -I/usr/lib/gcc/x86_64-linux-gnu/14/include
    - -I/usr/include/x86_64-linux-gnu
    - -I/usr/include

    # C++20 standard
    - -std=c++20

Diagnostics:
  UnusedIncludes: None
  MissingIncludes: None

